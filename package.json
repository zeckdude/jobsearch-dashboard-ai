{
  "name": "jobseach-dashboard-ai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "db:reset": "prisma migrate reset",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "prisma db seed",
    "mcp:server": "tsx scripts/mcp-server.ts",
    "assistant:install": "python3 -m venv .venv-assistant && .venv-assistant/bin/python -m pip install --upgrade pip && .venv-assistant/bin/python -m pip install -r requirements-local.txt && .venv-assistant/bin/python -m playwright install chromium",
    "assistant:apply": ".venv-assistant/bin/python scripts/playwright_assistant.py"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@mui/icons-material": "^9.0.1",
    "@mui/material": "^9.0.1",
    "@prisma/client": "^5.22.0",
    "mammoth": "^1.12.0",
    "next": "^13.5.11",
    "openai": "^6.37.0",
    "pdfjs-dist": "^3.11.174",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^13.5.11",
    "postcss": "^8.4.49",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5"
  }
}
