{
  "manifest_version": 3,
  "name": "Job Search OS",
  "description": "Capture jobs and fill ready application forms from the local Job Search OS app.",
  "version": "0.1.0",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Capture job"
  },
  "permissions": ["activeTab", "scripting", "storage", "tabs"],
  "host_permissions": ["http://localhost:3000/*", "http://127.0.0.1:3000/*"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
